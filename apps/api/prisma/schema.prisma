datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trips         TripMember[]
  expensesPaid  Expense[]    @relation("ExpensePayer")
  expenseShares ExpenseShare[]
  refreshTokens RefreshToken[]
  activities    Activity[]
  votes         Vote[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Trip {
  id          String   @id @default(uuid())
  name        String
  description String?
  destination String?
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  currency    String   @default("INR")
  coverImage  String?
  status      TripStatus @default(PLANNING)
  inviteCode  String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members    TripMember[]
  itinerary  ItineraryItem[]
  expenses   Expense[]
  polls      Poll[]
  activities Activity[]
}

model TripMember {
  id     String   @id @default(uuid())
  userId String
  tripId String
  role   MemberRole @default(MEMBER)
  joinedAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  @@unique([userId, tripId])
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum TripStatus {
  PLANNING
  UPCOMING
  ACTIVE
  COMPLETED
}

model ItineraryItem {
  id          String   @id @default(uuid())
  tripId      String
  title       String
  description String?
  type        ItineraryType @default(ACTIVITY)
  location    String?
  startTime   DateTime
  endTime     DateTime?
  cost        Float?
  bookingRef  String?
  order       Int      @default(0)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

enum ItineraryType {
  FLIGHT
  HOTEL
  ACTIVITY
  RESTAURANT
  TRANSPORT
  OTHER
}

model Expense {
  id          String   @id @default(uuid())
  tripId      String
  title       String
  description String?
  amount      Float
  currency    String   @default("INR")
  category    ExpenseCategory @default(OTHER)
  paidById    String
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  trip    Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  paidBy  User   @relation("ExpensePayer", fields: [paidById], references: [id])
  shares  ExpenseShare[]
}

model ExpenseShare {
  id        String   @id @default(uuid())
  expenseId String
  userId    String
  amount    Float
  settled   Boolean  @default(false)
  settledAt DateTime?
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([expenseId, userId])
}

enum ExpenseCategory {
  ACCOMMODATION
  TRANSPORT
  FOOD
  ACTIVITIES
  SHOPPING
  OTHER
}

model Poll {
  id        String   @id @default(uuid())
  tripId    String
  question  String
  status    PollStatus @default(ACTIVE)
  createdBy String
  createdAt DateTime @default(now())
  endsAt    DateTime?
  trip    Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  options PollOption[]
  votes   Vote[]
}

model PollOption {
  id     String @id @default(uuid())
  pollId String
  text   String
  order  Int    @default(0)
  poll  Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes Vote[]
}

model Vote {
  id       String   @id @default(uuid())
  pollId   String
  optionId String
  userId   String
  votedAt  DateTime @default(now())
  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([pollId, userId])
}

enum PollStatus {
  ACTIVE
  CLOSED
}

model Activity {
  id          String   @id @default(uuid())
  tripId      String
  type        ActivityType
  description String
  userId      String
  metadata    Json?
  createdAt   DateTime @default(now())
  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ActivityType {
  TRIP_CREATED
  MEMBER_JOINED
  ITINERARY_ADDED
  EXPENSE_ADDED
  EXPENSE_SETTLED
  POLL_CREATED
  VOTE_CAST
  AI_USED
  TRIP_UPDATED
}
