{
  "name": "tripsync",
  "version": "1.0.0",
  "description": "Collaborative Group Travel Planner",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm -F @tripsync/api db:generate",
    "db:migrate": "pnpm -F @tripsync/api db:migrate",
    "db:seed": "pnpm -F @tripsync/api db:seed",
    "db:studio": "pnpm -F @tripsync/api db:studio",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
